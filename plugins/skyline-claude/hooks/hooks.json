{
  "description": "SessionStart steer to prefer skyline MCP tools over built-in file tools, plus PreToolUse enforcement that redirects Read/Edit/Write to skyline equivalents when the daemon is running (fail-open when it is not).",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/skyline-enforce.sh\" read",
            "statusMessage": "Checking skyline..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/skyline-enforce.sh\" edit",
            "statusMessage": "Checking skyline..."
          }
        ]
      }
    ]
  }
}
