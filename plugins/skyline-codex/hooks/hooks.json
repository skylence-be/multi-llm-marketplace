{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"${CODEX_PLUGIN_ROOT}\"; sh \"$PLUGIN_ROOT/hooks/session-start.sh\"",
            "statusMessage": "Loading skyline guidance"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"${CODEX_PLUGIN_ROOT}\"; bash \"$PLUGIN_ROOT/hooks/skyline-enforce.sh\" read",
            "statusMessage": "Checking skyline..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"${CODEX_PLUGIN_ROOT}\"; bash \"$PLUGIN_ROOT/hooks/skyline-enforce.sh\" edit",
            "statusMessage": "Checking skyline..."
          }
        ]
      }
    ]
  }
}
