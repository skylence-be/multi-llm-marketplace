{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"${CODEX_PLUGIN_ROOT:-/Users/jv/Code/skylence/marketplaces/multi-llm-marketplace/plugins/agent-org-codex}\"; sh \"$PLUGIN_ROOT/hooks/agent-org-session-start.sh\"",
            "statusMessage": "Loading agent-org Codex guidance"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"${CODEX_PLUGIN_ROOT:-/Users/jv/Code/skylence/marketplaces/multi-llm-marketplace/plugins/agent-org-codex}\"; python3 \"$PLUGIN_ROOT/hooks/build-slot-guard.py\"",
            "statusMessage": "Checking agent-org build-slot policy"
          }
        ]
      }
    ]
  }
}
